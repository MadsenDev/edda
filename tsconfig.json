{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["bun-types", "react", "react-dom"],
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": ["src", "tests"]
}
