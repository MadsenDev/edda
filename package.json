{
  "name": "edda",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot ./src/index.html",
    "build": "bun build ./src/index.html --outdir dist --minify --sourcemap",
    "start": "bun ./src/index.html",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "react": "18",
    "react-dom": "18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "^1.3.14",
    "@types/react": "18",
    "@types/react-dom": "18",
    "typescript": "^6.0.3"
  }
}
